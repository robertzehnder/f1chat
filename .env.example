# Postgres: NEON_* wins over DATABASE_URL / DB_* (keep local + Neon side by side)
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# NEON_DB_HOST=... NEON_DB_PORT=5432 NEON_DB_NAME=neondb NEON_DB_USER=... NEON_DB_PASSWORD=...
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=openf1
DB_USER=openf1
DB_PASSWORD=openf1_local_dev

# Ingestion defaults
OPENF1_DATA_DIR=./data
OPENF1_INGEST_MODE=upsert
OPENF1_CHUNK_SIZE=100000
