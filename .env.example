# Postgres env precedence (resolved by web/src/lib/db.ts):
#   NEON_DATABASE_URL > DATABASE_URL > NEON_DB_* > local DB_*

# Pooled Neon URL (Phase 6 — wins first; in production must be a -pooler host on port 6543)
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech:6543/neondb?sslmode=require

# Read-replica pooled URL (Phase 12 item 1 — read-replica contract; not yet wired into pool.read)
# NEON_DATABASE_URL_REPLICA=postgresql://USER:PASSWORD@ep-xxxx-replica-pooler.region.aws.neon.tech:6543/neondb?sslmode=require

# Generic fallback URL (consumed via firstUrl("NEON_DATABASE_URL", "DATABASE_URL"))
# DATABASE_URL=postgresql://USER:PASSWORD@host:5432/dbname

# Per-component Neon override block (consumed by the NEON_DB_HOST branch in createPool() — used when no *_DATABASE_URL is set)
# NEON_DB_HOST=ep-xxxx.region.aws.neon.tech
# NEON_DB_PORT=5432
# NEON_DB_NAME=neondb
# NEON_DB_USER=neon_user
# NEON_DB_PASSWORD=neon_password

# SSL toggle (orthogonal to the precedence above — overrides the default neon.tech-host heuristic in sslForHost(); both keys read by the same helper)
# DB_SSL=true
# NEON_SSL=true

# Local Docker Postgres (used when none of NEON_DATABASE_URL, DATABASE_URL, or NEON_DB_HOST is set)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=openf1
DB_USER=openf1
DB_PASSWORD=openf1_local_dev

# Ingestion defaults
OPENF1_DATA_DIR=./data
OPENF1_INGEST_MODE=upsert
OPENF1_CHUNK_SIZE=100000
