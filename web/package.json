{
  "name": "openf1-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:grading": "node --test scripts/tests/*.test.mjs",
    "healthcheck:chat": "node scripts/chat-health-check.mjs",
    "healthcheck:chat:intense": "node scripts/chat-health-check.mjs --rubric scripts/chat-health-check.rubric.intense.json",
    "healthcheck:grade": "node scripts/chat-health-check-grade.mjs",
    "healthcheck:grade:intense": "node scripts/chat-health-check-grade.mjs --rubric scripts/chat-health-check.rubric.intense.json",
    "verify": "npm run typecheck && npm run test:grading && npm run build"
  },
  "dependencies": {
    "next": "^15.5.15",
    "pg": "^8.13.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
